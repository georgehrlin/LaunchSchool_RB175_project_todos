<section id="todos" class="<%= generate_class_complete(@list) %>">
  <header>
    <h2><%= @list[:name] %></h2>
    <ul>
      <li>
        <form action="/lists/<%= @list_id %>/complete_all" method="post">
          <button class="check" type="submit">Complete All</button>
        </form>
      </li>
      <li>
        <a class="edit" href="/lists/<%= @list_id %>/edit">Edit List</a>
      </li>
    </ul>
  </header>
  <ul>
    <% sort_todos(@list[:todos]) do |todo, index| %>
      <li class="<%= todo[:completed] ? "complete" : "" %>">
        <form class="check" action="/lists/<%= @list_id %>/todos/<%= index %>" method="post">
          <input type="hidden" name="completed" value="<%= !todo[:completed] %>">
          <button type="submit" name="todo_index" value="<%= index %>"></button>
        </form>
        <h3><label for="todo"><%= "#{todo[:name]}" %></label></h3>
        <form class="delete" action="/lists/<%= @list_id %>/todos/<%= index %>/delete" method="post">
          <button type="submit" name="todo_index" value="<%= index %>">Delete</button>
        </form>
      </li>
    <% end %>
  </ul>
</section>

<form action="/lists/<%= @list_id %>/todos" method="post">
  <dl>
    <dt>
      <label for="todo">Enter a new todo item:</label>
    </dt>
    <dd>
      <input name="todo" id="todo" type="text" placeholder="Something to do" value="<%= params[:todo] %>">
    </dd>
  </dl>
  <fieldset>
    <input type="submit" value="Add">
  </fieldset>
</form>

<% content_for :header_links do %>
  <a class="list" href="/lists">All Lists</a>
<% end %>
